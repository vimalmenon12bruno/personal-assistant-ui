# Copy to .env.local and fill in your values
# NEVER commit .env.local to git

# Hyperspace AI API key
HYPERSPACE_API_KEY=84bbbebd-cdb8-46e9-bf7a-6bf3ecceb2ba

# Hyperspace AI base URL (the local desktop app proxy)
# For local dev: http://localhost:6655/anthropic
# For Vercel: your Hyperspace cloud endpoint (if available)
HYPERSPACE_BASE_URL=http://localhost:6655/anthropic

# Model name as exposed by Hyperspace
HYPERSPACE_MODEL=anthropic--claude-4.8-opus
